{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: build example/testing",
      "type": "shell",
      "command": "task",
      "args": ["build", "PRESET=example", "TARGET=testing"],
      "options": {
        "cwd": "${workspaceFolder}/example"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Build example/testing using CMake"
    }
  ]
}
