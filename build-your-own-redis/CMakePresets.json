{
  "version": 4,
  "configurePresets": [
    {
      "name": "redis",
      "displayName": "BuildYourOwnRedis Configure Preset",
      "description": "Configure Preset to use with the redis",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/install",
        "BUILD_TESTING": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "redis",
      "displayName": "BuildYourOwnRedis Build Preset",
      "description": "Build Preset to use with the redis",
      "configurePreset": "redis"
    }
  ]
}